#include <iostream>
using namespace std;

int main() {
    double num1, num2;
    char op;

    cout << "Enter first number: ";
    cin >> num1;

    cout << "Enter operator (+, -, *, /): ";
    cin >> op;

    cout << "Enter second number: ";
    cin >> num2;

    switch(op) {
        case 'addition':
            cout << "Result = " << num1 + num2;
            break;
        case 'subtraction':
            cout << "Result = " << num1 - num2;
            break;
        case 'multiplication':
            cout << "Result = " << num1 * num2;
            break;
        case 'division':
            if(num2 != 0)
                cout << "Result = " << num1 / num2;
            else
                cout << "Error! Division by zero.";
            break;
        default:
            cout << "Invalid operator!";
    }

    return 0;
}
